{
  "name": "mpprouter",
  "version": "1.0.0",
  "description": "Cost-optimized API router with MCP support and automatic MPP micropayments",
  "main": "index.js",
  "bin": {
    "mpprouter": "./bin/mpprouter.mjs"
  },
  "files": [
    "bin/",
    "src/mcp/client.ts",
    "README.md"
  ],
  "scripts": {
    "dev": "npx tsx --env-file=.env src/index.ts",
    "start": "./node_modules/.bin/tsx --env-file=.env src/index.ts --no-tui",
    "demo": "npx tsx scripts/demo.ts"
  },
  "keywords": [
    "mcp",
    "mpp",
    "micropayments",
    "api-router",
    "tempo"
  ],
  "author": "richtan",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/richtan/mpprouter.git"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^12.8.0",
    "blessed": "^0.1.81",
    "blessed-contrib": "^4.11.0",
    "hono": "^4.12.8",
    "mppx": "^0.4.7",
    "tsx": "^4.21.0",
    "viem": "^2.47.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/blessed": "^0.1.27",
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3"
  }
}
